---
import { Image } from "astro:assets";
import reviewBbbLogo from "@assets/images/logos/BBB-Accredited-Business-176w.webp";
import brandLogoWhite from "@assets/images/brand/hygienic-air-logo-white.png";

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  navLinks: NavLink[];
}

const { navLinks } = Astro.props;
const quickLinks = navLinks.slice(0, 6);

const businessHours = [
  { day: "Monday", hours: "7:00 am - 8:00 pm" },
  { day: "Tuesday", hours: "7:00 am - 8:00 pm" },
  { day: "Wednesday", hours: "7:00 am - 8:00 pm" },
  { day: "Thursday", hours: "7:00 am - 8:00 pm" },
  { day: "Friday", hours: "7:00 am - 8:00 pm" },
  { day: "Saturday", hours: "7:00 am - 7:00 pm" },
  { day: "Sunday", hours: "8:00 am - 5:00 pm" },
];
---

<footer class="site-footer">
  <div class="u-container site-footer__top">
    <div>
      <a href="/" aria-label="Hygienic Air home">
        <Image
          class="site-footer__brand-logo"
          src={brandLogoWhite}
          alt="Hygienic Air white logo"
          width={320}
          height={91}
        />
      </a>
      <p>Professional duct, dryer duct, and chimney cleaning services across Florida.</p>

      <div class="footer-socials" aria-label="Social links">
        <a href="https://www.facebook.com/hygienicair" target="_blank" rel="noreferrer" aria-label="Visit us on Facebook">
          <span class="social-icon social-icon--facebook" aria-hidden="true">f</span>
        </a>
        <a href="http://google.com/search?q=Hygienic+Air+Plus" target="_blank" rel="noreferrer" aria-label="View Google profile">
          <span class="social-icon social-icon--google" aria-hidden="true">G</span>
        </a>
        <a href="https://www.bbb.org/us/fl/clermont/profile/air-duct-cleaning/hygienic-air-plus-0733-90445717" target="_blank" rel="noreferrer" aria-label="View BBB accreditation">
          <Image
            src={reviewBbbLogo}
            alt="BBB Accredited Business"
            width={96}
            height={36}
          />
        </a>
      </div>
    </div>

    <nav aria-label="Footer navigation">
      <h3>Quick Links</h3>
      <ul>
        {quickLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer-contact">
      <h3>Business Hours</h3>
      <dl class="footer-hours">
        {businessHours.map((entry) => (
          <>
            <dt>{entry.day}</dt>
            <dd>{entry.hours}</dd>
          </>
        ))}
      </dl>

      <h3>Contact</h3>
      <p><a href="tel:+13528012788">(352) 801-2788</a></p>
      <p><a href="mailto:info@hygienicairplus.com">info@hygienicairplus.com</a></p>
      <p>License #</p>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="u-container">
      <p>© Hygienic Air, Inc</p>
      <a href="https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c" target="_blank" rel="noreferrer">Login Customer Portal</a>
      <a href="http://wisetack.us/#/mxr0gum/prequalify" target="_blank" rel="noreferrer">Discover Financial Solutions</a>
    </div>
  </div>
</footer>
