---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface LogoItem {
  src: ImageMetadata;
  alt: string;
  href: string;
}

interface Props {
  id: string;
  label: string;
  items: LogoItem[];
}

const { id, label, items } = Astro.props;
---

<div class="logo-slider" data-logo-slider id={id} aria-label={label}>
  <button class="carousel-arrow" type="button" data-logo-prev aria-label="Previous logos">‹</button>

  <div class="logo-slider__viewport">
    <ul class="logo-slider__track" data-logo-track>
      {items.map((item) => (
        <li class="logo-slider__slide">
          <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.alt}>
            <Image src={item.src} alt={item.alt} loading="lazy" />
          </a>
        </li>
      ))}
    </ul>
  </div>

  <button class="carousel-arrow" type="button" data-logo-next aria-label="Next logos">›</button>
</div>

<script is:inline>
  (() => {
    const initLogoSliders = () => {
      const sliders = Array.from(document.querySelectorAll("[data-logo-slider]"));

      sliders.forEach((slider) => {
        if (slider.dataset.bound === "true") return;
        slider.dataset.bound = "true";

        const track = slider.querySelector("[data-logo-track]");
        const prev = slider.querySelector("[data-logo-prev]");
        const next = slider.querySelector("[data-logo-next]");
        const total = track?.children.length || 0;

        if (!track || total <= 1) {
          prev?.setAttribute("disabled", "true");
          next?.setAttribute("disabled", "true");
          return;
        }

        let index = 0;

        const getPerView = () => (window.matchMedia("(max-width: 42rem)").matches ? 1 : 3);

        const update = () => {
          const perView = getPerView();
          const maxIndex = Math.max(total - perView, 0);
          if (index > maxIndex) index = maxIndex;
          if (index < 0) index = 0;

          slider.style.setProperty("--logo-per-view", String(perView));
          track.style.transform = `translateX(-${index * (100 / perView)}%)`;
          prev?.toggleAttribute("disabled", index <= 0);
          next?.toggleAttribute("disabled", index >= maxIndex);
        };

        prev?.addEventListener("click", () => {
          index -= 1;
          update();
        });

        next?.addEventListener("click", () => {
          index += 1;
          update();
        });

        window.addEventListener("resize", update, { passive: true });
        update();
      });
    };

    initLogoSliders();
    document.addEventListener("astro:page-load", initLogoSliders);
  })();
</script>
