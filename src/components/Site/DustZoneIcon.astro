---
interface Props {
  variant:
    | "system"
    | "surface"
    | "niche"
    | "fan"
    | "cabinet"
    | "beams"
    | "transom"
    | "manual"
    | "ladder"
    | "shield"
    | "camera"
    | "sparkle"
    | "clipboard"
    | "sliders";
}

const { variant } = Astro.props;
---

{variant === "system" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="8" width="18" height="8" rx="2"></rect>
    <line x1="8" y1="8" x2="8" y2="16"></line>
    <line x1="16" y1="8" x2="16" y2="16"></line>
    <circle cx="6" cy="12" r="0.9"></circle>
    <circle cx="18" cy="12" r="0.9"></circle>
  </svg>
)}

{variant === "surface" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="12" width="18" height="7" rx="1.4"></rect>
    <path d="M12 4l1.2 2.6L16 8l-2.8 1.4L12 12l-1.2-2.6L8 8l2.8-1.4z"></path>
  </svg>
)}

{variant === "niche" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
    <path d="M7 21v-7a5 5 0 0 1 10 0v7"></path>
  </svg>
)}

{variant === "fan" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <circle cx="12" cy="12" r="1.6"></circle>
    <circle cx="12" cy="6" r="2.6"></circle>
    <circle cx="18" cy="12" r="2.6"></circle>
    <circle cx="12" cy="18" r="2.6"></circle>
    <circle cx="6" cy="12" r="2.6"></circle>
  </svg>
)}

{variant === "cabinet" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="6" width="18" height="12" rx="1.8"></rect>
    <line x1="12" y1="6" x2="12" y2="18"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
  </svg>
)}

{variant === "beams" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <line x1="3" y1="7" x2="21" y2="7"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="17" x2="21" y2="17"></line>
    <line x1="7" y1="7" x2="7" y2="17"></line>
    <line x1="17" y1="7" x2="17" y2="17"></line>
  </svg>
)}

{variant === "transom" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="4" width="18" height="16" rx="2"></rect>
    <line x1="3" y1="9" x2="21" y2="9"></line>
    <line x1="12" y1="9" x2="12" y2="20"></line>
  </svg>
)}

{variant === "manual" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <path d="M4 20h6l1.5-5H5.5z"></path>
    <path d="M11.5 15l8.5-8.5-2.5-2.5-8.5 8.5"></path>
    <line x1="16" y1="5.5" x2="18.5" y2="8"></line>
  </svg>
)}

{variant === "ladder" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <line x1="8" y1="3" x2="8" y2="21"></line>
    <line x1="16" y1="3" x2="16" y2="21"></line>
    <line x1="8" y1="7" x2="16" y2="7"></line>
    <line x1="8" y1="11" x2="16" y2="11"></line>
    <line x1="8" y1="15" x2="16" y2="15"></line>
    <line x1="8" y1="19" x2="16" y2="19"></line>
  </svg>
)}

{variant === "shield" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <path d="M12 3l7 3v5.5c0 4.2-2.6 7.5-7 9.5-4.4-2-7-5.3-7-9.5V6z"></path>
    <path d="M9 12.5l2 2 4-4"></path>
  </svg>
)}

{variant === "camera" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="3" y="7" width="18" height="13" rx="2"></rect>
    <path d="M9 7l1.3-2h3.4L15 7"></path>
    <circle cx="12" cy="13.5" r="3.2"></circle>
  </svg>
)}

{variant === "sparkle" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5z"></path>
    <path d="M5 14l.8 1.8L7.6 16l-1.8.8L5 18.6l-.8-1.8L2.4 16l1.8-.2z"></path>
    <path d="M18.5 14.5l.9 2.1 2.1.9-2.1.9-.9 2.1-.9-2.1-2.1-.9 2.1-.9z"></path>
  </svg>
)}

{variant === "clipboard" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <rect x="6" y="4" width="12" height="17" rx="2"></rect>
    <rect x="9" y="2.5" width="6" height="3" rx="1"></rect>
    <path d="M9 12l2 2 4-4"></path>
  </svg>
)}

{variant === "sliders" && (
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="service-icon-svg" style="fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;">
    <line x1="6" y1="4" x2="6" y2="20"></line>
    <line x1="12" y1="4" x2="12" y2="20"></line>
    <line x1="18" y1="4" x2="18" y2="20"></line>
    <circle cx="6" cy="9" r="2"></circle>
    <circle cx="12" cy="15" r="2"></circle>
    <circle cx="18" cy="11" r="2"></circle>
  </svg>
)}
