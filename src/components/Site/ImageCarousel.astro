---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface ImageSlide {
  src: string | ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  id: string;
  label: string;
  items: ImageSlide[];
  fit?: "cover" | "contain";
}

const { id, label, items, fit = "cover" } = Astro.props;
---

<div class="media-carousel" data-media-carousel data-fit={fit} id={id} aria-label={label}>
  <button class="carousel-arrow" type="button" data-carousel-prev aria-label="Previous slide">‹</button>

  <div class="media-carousel__viewport">
    <div class="media-carousel__track" data-carousel-track>
      {items.map((item, index) => (
        <figure class="media-carousel__slide">
          <a
            href={typeof item.src === "string" ? item.src : item.src.src}
            data-lightbox-item
            data-index={index}
            aria-label={`Open image ${index + 1}`}
          >
            {typeof item.src === "string" ? (
              <img src={item.src} alt={item.alt} loading="lazy" />
            ) : (
              <Image src={item.src} alt={item.alt} loading="lazy" />
            )}
          </a>
          {item.caption && <figcaption>{item.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </div>

  <button class="carousel-arrow" type="button" data-carousel-next aria-label="Next slide">›</button>
</div>

<script is:inline>
  (() => {
    const initCarousels = () => {
      const carousels = Array.from(document.querySelectorAll("[data-media-carousel]"));

      carousels.forEach((carousel) => {
        if (carousel.dataset.bound === "true") return;
        carousel.dataset.bound = "true";

        const track = carousel.querySelector("[data-carousel-track]");
        const prev = carousel.querySelector("[data-carousel-prev]");
        const next = carousel.querySelector("[data-carousel-next]");
        const total = track?.children.length || 0;

        if (!track || total <= 1) {
          prev?.setAttribute("disabled", "true");
          next?.setAttribute("disabled", "true");
          return;
        }

        let index = 0;

        const getPerView = () => {
          if (window.matchMedia("(max-width: 42rem)").matches) return 1;
          if (window.matchMedia("(max-width: 64rem)").matches) return 2;
          if (window.matchMedia("(max-width: 82rem)").matches) return 3;
          return 4;
        };

        const setSlide = (nextIndex) => {
          const perView = getPerView();
          const maxIndex = Math.max(total - perView, 0);
          if (nextIndex < 0) {
            index = 0;
          } else if (nextIndex > maxIndex) {
            index = maxIndex;
          } else {
            index = nextIndex;
          }

          carousel.style.setProperty("--media-per-view", String(perView));
          track.style.transform = `translateX(-${index * (100 / perView)}%)`;
          prev?.toggleAttribute("disabled", index <= 0);
          next?.toggleAttribute("disabled", index >= maxIndex);
        };

        prev?.addEventListener("click", () => setSlide(index - 1));
        next?.addEventListener("click", () => setSlide(index + 1));
        window.addEventListener("resize", () => setSlide(index), { passive: true });
        setSlide(0);
      });
    };

    initCarousels();
    document.addEventListener("astro:page-load", initCarousels);
  })();
</script>
