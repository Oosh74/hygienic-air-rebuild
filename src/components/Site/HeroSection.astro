---
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
}

interface Props {
  imageUrl: string;
  topper?: string;
  title: string;
  body: string;
  actions?: Action[];
  align?: "center" | "left-bottom";
}

const {
  imageUrl,
  topper = "Central Florida Air Duct Experts",
  title,
  body,
  actions = [],
  align = "center",
} = Astro.props;
---

<section class:list={["hero", { "hero--left-bottom": align === "left-bottom" }]} style={`--hero-image: url('${imageUrl}')`}>
  <div class="hero__overlay"></div>
  <div class="u-container hero__content content-stack">
    <p class="section-topper content-stack__topper">{topper}</p>
    <h1 class="content-stack__title">{title}</h1>
    <p class="content-stack__body">{body}</p>

    {actions.length > 0 && (
      <div class="hero__actions content-stack__actions">
        {actions.map((action) => (
          <a
            href={action.href}
            class={`btn btn--${action.variant || "primary"}`}
            target={action.external ? "_blank" : undefined}
            rel={action.external ? "noreferrer" : undefined}
          >
            {action.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
