---
import { Image } from "astro:assets";
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import ImageCarousel from "@components/Site/ImageCarousel.astro";
import Lightbox from "@components/Site/Lightbox.astro";
import commercialAirIndicatorImage from "@assets/images/services/commercial-air-duct/hygienic-air-commercial-air-indicator.jpg";
import commercialAirSchoolEpaImage from "@assets/images/services/commercial-air-duct/hygienic-air-commercial-school-epa-example.jpg";

const heroImageUrl = "/images/heroes/commercial-air-duct-hero.jpg";

const indoorAirStats = [
  {
    value: "Top 5",
    label: "Indoor air pollution ranks among the top environmental dangers.",
  },
  {
    value: "2.31M",
    label: "Deaths worldwide were attributed to indoor pollution in the latest year.",
  },
  {
    value: "90%",
    label: "Of our lives are spent indoors.",
  },
  {
    value: "40 lbs",
    label: "The average home collects about 40 pounds of dust yearly.",
  },
  {
    value: "150,000+",
    label: "Quarts of air are inhaled per person per day (approximately).",
  },
  {
    value: "8x/hr",
    label: "Indoor air is circulated up to 8 times per hour through the building.",
  },
  {
    value: "Up to 5x",
    label: "Indoor air can be more polluted than outdoor air.",
  },
];

const warningSigns = [
  "Have your air ducts been cleaned in the last 1 to 2 years?",
  "Are you dusting daily?",
  "Do you have allergies, asthma, or feel like you are always sick?",
  "Do you smell a musty odor when your HVAC system is on?",
  "Are you unable to get rid of pet, nicotine, or other odors?",
  "Have you completed construction or renovations recently?",
  "Do you see visible dirt or mold on vent covers or nearby surfaces?",
];

const businessIndicators = [
  "Do your vent/register covers have visible dust buildup?",
  "Is the ceiling or wall around vents turning black?",
  "Is dust building up on desks, counters, or furniture quickly?",
  "Are teams dusting more frequently than usual?",
  "Have your air ducts gone 3 to 5 years without cleaning?",
];

const hvacComponents = [
  "Air ducts",
  "Air cleaner",
  "Air filter",
  "Air plenum",
  "Coils",
  "Grills",
  "Drain pan",
  "Registers",
  "Blower motor and assembly",
  "Heat exchanger",
];

const galleryItems = [
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-1.jpg",
    alt: "Commercial duct interior with heavy dust buildup before cleaning.",
  },
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-2.jpg",
    alt: "Commercial vent and duct surface requiring deep cleaning.",
  },
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-3.jpg",
    alt: "Industrial ductwork cleaning project in progress.",
  },
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-4.jpg",
    alt: "Large-scale commercial air duct cleaning setup.",
  },
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-5.jpg",
    alt: "Poor indoor-air indicator near duct-related system area.",
  },
  {
    src: "/images/commercial-air-duct/gallery/air-duct-commercial-6.jpg",
    alt: "Vacuum truck and filtration equipment supporting commercial cleaning.",
  },
];
---

<SiteLayout
  title="Commercial Air Duct Cleaning in Central Florida"
  description="Commercial and industrial air duct cleaning services in Central Florida focused on indoor air quality, safer workplaces, and cleaner HVAC systems."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Good Air in Workplace"
    title="Commercial & Industrial Air Duct Cleaning"
    body="At Hygienic Air, Inc, we're committed to enhancing the air quality of your home through our comprehensive residential services. Our meticulous air duct cleanings completed by our experienced, certified technicians ensure that every corner is free from contaminants, allergens, and debris. With over two decades of experience serving Central Florida, we pride ourselves on delivering top-tier service and unparalleled results. Trust us to create a healthier living environment for you and your loved ones, where every breath is cleaner, fresher, and safer. Contact us today to experience the Hygienic Air difference firsthand!"
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Commercial Air Duct Services</p>
        <h2 class="section-title">Air Duct Cleaning for Your Business</h2>
      </header>

      <div class="split-grid content-grid">
        <article class="rich-text">
          <p>
            As a business, maintaining a productive, safe, and healthful work environment is
            essential for efficient operations and employee retention. One key factor is indoor air
            quality.
          </p>
          <p>
            According to the EPA, indoor air can be five to seven times more polluted than outdoor
            air. Poor indoor air quality can impact employee performance and increase absenteeism,
            reducing overall productivity.
          </p>
          <p>
            The EPA ranks indoor air pollution (sick building syndrome) among the top five
            environmental risks to public health, and contaminants in ductwork are a major
            contributor. To improve workplace indoor air quality, start with Hygienic Air, Inc.
          </p>
        </article>

        <aside class="notice-box">
          <h3>Do You Need Air Duct Cleaning?</h3>
          <ul class="check-list">
            {warningSigns.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--deep-blue">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Indoor Air Facts</p>
        <h2 class="section-title">Why Routine Duct Cleaning Matters</h2>
      </header>

      <div class="metric-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
        {indoorAirStats.map((item) => (
          <article class="metric-card">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">View Our Gallery</p>
        <h2 class="section-title">Commercial Air Duct Projects</h2>
      </header>

      <ImageCarousel
        id="commercial-air-gallery"
        label="Commercial and industrial air duct project gallery"
        items={galleryItems}
        fit="contain"
      />
    </div>
  </section>

  <section class="section">
    <div class="u-container split-grid">
      <article class="notice-box">
        <h3>Does Your Business Have Poor Indoor Air Quality?</h3>
        <p>
          These are key indicators that can signal poor indoor air quality in your business.
        </p>
        <ul class="feature-list" style="margin-top: var(--space-s);">
          {businessIndicators.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <figure class="service-inline-media">
        <Image
          src={commercialAirIndicatorImage}
          alt="Visible buildup and dirty material indicating poor indoor air quality conditions."
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">HVAC Scope</p>
        <h2 class="section-title">Components Included in Full-System Cleaning</h2>
      </header>

      <div class="notice-box" style="max-width: 74ch; margin: 0 auto;">
        <ul class="feature-list" style="grid-template-columns: repeat(2, minmax(0, 1fr));">
          {hvacComponents.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Air Duct Cleaning Process</p>
        <h2 class="section-title">Source Removal with Negative Pressure</h2>
      </header>

      <div class="rich-text" style="max-width: 78ch; margin: 0 auto;">
        <p>
          The most effective way to clean air ducts is through source-removal methods. The HVAC
          system is placed under negative pressure using specialized vacuum trucks. As the trucks
          draw air through the system, agitation whips are inserted to loosen dirt and debris from
          interior duct surfaces.
        </p>
        <p>
          Loosened contaminants are carried through the ducts into the vacuum trucks, removing them
          from the system and building without leaving mess behind.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--deep-blue">
    <div class="u-container split-grid service-inline-grid">
      <article class="service-inline-copy">
        <h3>Did You Know?</h3>
        <p>
          Schools can accommodate up to 4x more occupants (staff and students) than a regular
          office building with the same amount of conditioned space. Children often breathe more
          air relative to body weight than adults, and the EPA identifies school air quality as a
          major concern.
        </p>
        <p style="margin-top: var(--space-s);">
          EPA states: "Children may be more sensitive to pollution, and children with asthma are
          especially sensitive. Asthma is responsible for millions of missed school days each year.
          Parents' and caregivers' involvement helps daycare facilities become aware of asthma
          triggers and the need to reduce them."
        </p>
      </article>

      <figure class="service-inline-media">
        <Image
          src={commercialAirSchoolEpaImage}
          alt="Vacuum truck and filtration units parked outside commercial storefronts during service."
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <ContactOptionsSection />

  <Lightbox slot="after-body" />
</SiteLayout>
