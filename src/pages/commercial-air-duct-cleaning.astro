---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ServiceIcon from "@components/Site/ServiceIcon.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import ImageCarousel from "@components/Site/ImageCarousel.astro";
import Lightbox from "@components/Site/Lightbox.astro";

const heroImageUrl = "/images/heroes/commercial-air-duct-hero.jpg";

const warningSigns = [
  "Have your ducts gone 3 to 5 years without cleaning?",
  "Are employees reporting odors, irritation, or stale air?",
  "Do you notice musty smells when HVAC equipment starts?",
  "Did you recently complete remodeling or buildout work?",
  "Is visible dirt or debris collecting around supply or return vents?",
];

const processHighlights = [
  "System is placed under negative pressure with high-powered vacuum trucks.",
  "Agitation tools loosen buildup from duct interior surfaces.",
  "Debris is extracted directly into vacuum collection equipment.",
  "No loose dust is left circulating in occupied spaces.",
  "Service can be phased to match facility operating needs.",
];

const impacts = [
  {
    title: "Indoor Air Quality",
    body: "Contaminants in ductwork can contribute to poor indoor air quality and occupant discomfort.",
    icon: "residential" as const,
  },
  {
    title: "Workforce Performance",
    body: "Cleaner HVAC systems support healthier environments, helping reduce disruptions and absenteeism.",
    icon: "commercial" as const,
  },
  {
    title: "System Efficiency",
    body: "Cleaner airflow pathways reduce strain on HVAC components and support efficient operation.",
    icon: "industrial" as const,
  },
];

const facilityTypes = [
  "Office buildings and business parks",
  "Retail, hospitality, and mixed-use properties",
  "Healthcare and educational facilities",
  "Industrial operations and manufacturing spaces",
];

const galleryItems = [
  {
    src: "/images/cdn-migrated/453337629_1677824812952250_4148574405933219806_n-a2974961-1920w.jpg",
    alt: "Commercial duct cleaning at an industrial facility.",
  },
  {
    src: "/images/cdn-migrated/453304724_2202899220067420_5575271529760227530_n-ae3f3a79-1920w.jpg",
    alt: "Technicians servicing large commercial duct runs.",
  },
  {
    src: "/images/cdn-migrated/453293531_997099555218148_5821268677402918691_n-2a6523f0-1920w.jpg",
    alt: "Commercial airflow system cleaning equipment.",
  },
  {
    src: "/images/cdn-migrated/451622238_1153893099170938_3626138309021834960_n-7bffb50a-a7f4bb20-1920w.jpg",
    alt: "Crew performing duct cleaning in a commercial building.",
  },
  {
    src: "/images/cdn-migrated/453349336_474491078626899_5796806996728609189_n-c74a6e71-1920w.jpg",
    alt: "Facility ductwork cleaning project.",
  },
  {
    src: "/images/cdn-migrated/453277604_1033712348351469_5573308226265591582_n-304f417c-1920w.jpg",
    alt: "High-capacity duct cleaning setup at commercial site.",
  },
];
---

<SiteLayout
  title="Commercial Air Duct Cleaning in Central Florida"
  description="Commercial and industrial air duct cleaning services in Central Florida for improved indoor air quality, healthier facilities, and HVAC performance."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Commercial / Industrial Service"
    title="Commercial & Industrial Air Duct Cleaning"
    body="Keep facilities cleaner, safer, and more efficient with high-powered source-removal duct cleaning performed by experienced crews."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Air Duct Cleaning for Your Business</p>
        <h2 class="section-title">A Healthier Facility Starts with Cleaner Airflow</h2>
      </header>

      <div class="split-grid content-grid">
        <div class="rich-text">
          <p>
            Contaminants inside duct systems can recirculate through occupied areas throughout the
            day. That impacts comfort, cleanliness, and system performance in offices, retail,
            hospitality, education, and industrial environments.
          </p>
          <p>
            Hygienic Air, Inc delivers commercial source-removal cleaning that removes buildup from
            duct surfaces and captures debris at the truck, keeping dirt out of your indoor spaces.
          </p>
        </div>

        <aside class="notice-box">
          <h3>Do You Need Air Duct Cleaning?</h3>
          <ul class="check-list">
            {warningSigns.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Does Your Business Have Poor Indoor Air Quality?</p>
        <h2 class="section-title">Operational Impact</h2>
      </header>

      <div class="highlight-grid">
        {impacts.map((item) => (
          <article class="highlight-card">
            <div class="card-icon-wrap" aria-hidden="true">
              <ServiceIcon variant={item.icon} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>

      <div class="notice-box" style="margin-top: var(--space-l);">
        <h3>Air Duct Cleaning Process</h3>
        <ul class="feature-list">
          {processHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="notice-box" style="margin-top: var(--space-l);">
        <h3>Facilities We Commonly Serve</h3>
        <ul class="feature-list">
          {facilityTypes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">View Our Gallery</p>
        <h2 class="section-title">Commercial Air Duct Projects</h2>
      </header>

      <ImageCarousel
        id="commercial-air-gallery"
        label="Commercial and industrial air duct project gallery"
        items={galleryItems}
        fit="contain"
      />
    </div>
  </section>

  <ContactOptionsSection />

  <Lightbox slot="after-body" />
</SiteLayout>
