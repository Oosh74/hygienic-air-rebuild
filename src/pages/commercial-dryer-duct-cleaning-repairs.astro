---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ServiceIcon from "@components/Site/ServiceIcon.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import ImageCarousel from "@components/Site/ImageCarousel.astro";
import Lightbox from "@components/Site/Lightbox.astro";

const heroImageUrl = "/images/heroes/commercial-dryer-duct-hero.jpg";

const warningSigns = [
  "Dryers require multiple cycles to fully dry loads.",
  "Units smell unusually hot or burnt during operation.",
  "Laundry areas feel excessively warm or humid.",
  "Lint accumulation has increased around equipment.",
  "Flow sensors or fault lights are appearing on machines.",
  "Vents have not been cleaned on a regular schedule.",
];

const processSteps = [
  "Step 1: Connect high-powered vacuum equipment and establish negative pressure.",
  "Step 2: Agitate and remove lint buildup throughout the full exhaust path.",
  "Inspect terminations, guards, and vent conditions for restrictions.",
  "Document component damage and code-related concerns.",
  "Restore airflow and confirm cleaner, safer operation.",
];

const clientTypes = [
  "Hotels and hospitality facilities",
  "Multi-family properties and apartment communities",
  "Senior living and assisted living centers",
  "Laundry operations and uniform services",
  "Healthcare and educational campuses",
  "Commercial properties with shared laundry systems",
  "Industrial sites with high-volume dryer exhaust systems",
];

const processCards = [
  {
    title: "Negative Pressure Cleaning",
    body: "We place the full system under controlled suction to remove lint and debris at the source instead of redistributing contaminants.",
    icon: "residential" as const,
  },
  {
    title: "Airflow Restoration Testing",
    body: "Our process focuses on restoring vent performance, reducing run times, and lowering avoidable equipment strain.",
    icon: "commercial" as const,
  },
  {
    title: "Compliance-Aware Reporting",
    body: "We identify restrictions, unsafe terminations, and component issues, then provide clear recommendations for safer operation.",
    icon: "industrial" as const,
  },
];

const galleryItems = [
  {
    src: "/images/cdn-migrated/Screenshot-2024-06-17-203508-1-1920w.png",
    alt: "Dryer vent cover option for commercial installations.",
  },
  {
    src: "/images/cdn-migrated/Screenshot-2024-06-17-203508-2-1920w.png",
    alt: "Commercial vent termination detail.",
  },
  {
    src: "/images/cdn-migrated/453359145_1916531795523513_2013473620363757831_n-17b9c4cc-1920w.jpg",
    alt: "Commercial dryer vent cleaning project.",
  },
  {
    src: "/images/cdn-migrated/451691288_1212672889894340_2174070438138457470_n-62ae80e1-1920w.jpg",
    alt: "Technician servicing multi-unit dryer exhaust lines.",
  },
  {
    src: "/images/cdn-migrated/commercial-dryer-vent-cleaning-before-94237355-1920w.jpg",
    alt: "Before photo of lint buildup in commercial dryer vent.",
  },
  {
    src: "/images/cdn-migrated/commercial-dryer-vent-cleaning-after-1f3be960-1920w.jpg",
    alt: "After photo of cleaned commercial dryer vent.",
  },
];
---

<SiteLayout
  title="Commercial Dryer Vent Cleaning & Repair in Central Florida"
  description="Commercial and industrial dryer vent cleaning and repair services in Central Florida to reduce fire risk, improve airflow, and support safer operations."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Commercial / Industrial Service"
    title="Commercial / Industrial Dryer Duct Cleaning / Repair"
    body="Protect your property and equipment with scheduled dryer exhaust cleaning, airflow restoration, and compliance-aware recommendations."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">What Is Dryer Vent Cleaning?</p>
        <h2 class="section-title">Critical Maintenance for High-Use Dryer Systems</h2>
      </header>

      <div class="split-grid content-grid">
        <div class="rich-text">
          <p>
            Commercial dryer vent cleaning removes lint and debris from the full exhaust line, from
            machine connection to exterior discharge. Proper cleaning reduces restriction, shortens
            cycle times, and supports safe operation.
          </p>
          <p>
            NFPA data identifies uncleaned dryer vents as a leading contributor to dryer-related
            fires. Routine service also helps reduce wear, avoid downtime, and lower utility use.
          </p>
        </div>

        <aside class="notice-box">
          <h3>Warning Signs It's Time to Clean</h3>
          <ul class="check-list">
            {warningSigns.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Our Process</p>
        <h2 class="section-title">How Our Process Is Different</h2>
      </header>

      <div class="info-card-grid">
        {processCards.map((item) => (
          <article class="info-card">
            <div class="card-icon-wrap" aria-hidden="true">
              <ServiceIcon variant={item.icon} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>

      <div class="notice-box" style="margin-top: var(--space-l);">
        <h3>Service Workflow</h3>
        <ul class="feature-list">
          {processSteps.map((step) => <li>{step}</li>)}
        </ul>
      </div>

      <div class="notice-box" style="margin-top: var(--space-l);">
        <h3>Commercial Clients We Commonly Serve</h3>
        <ul class="feature-list">
          {clientTypes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">View Our Gallery</p>
        <h2 class="section-title">Commercial Dryer Vent Projects</h2>
      </header>

      <ImageCarousel
        id="commercial-dryer-gallery"
        label="Commercial dryer vent project gallery"
        items={galleryItems}
        fit="contain"
      />
    </div>
  </section>

  <ContactOptionsSection />

  <Lightbox slot="after-body" />
</SiteLayout>
