---
import { Image } from "astro:assets";
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ServiceIcon from "@components/Site/ServiceIcon.astro";
import TestimonialSlider from "@components/Site/TestimonialSlider.astro";
import Lightbox from "@components/Site/Lightbox.astro";
import { homeGalleryImages } from "@data/gallery-images";
import { testimonials } from "@data/reviews";

const heroImageUrl = "/images/heroes/home-hero.jpg";

const services = [
  {
    title: "Residential",
    body: "Air duct, dryer duct, and chimney cleaning/repairs designed to improve indoor air quality and system performance.",
    href: "/services",
    icon: "residential" as const,
  },
  {
    title: "Commercial",
    body: "Commercial air systems cleaned with high-powered equipment for cleaner airflow, compliance, and safer facilities.",
    href: "/commercial-air-duct-cleaning",
    icon: "commercial" as const,
  },
  {
    title: "Industrial",
    body: "High-dust zone and combustible dust-focused cleaning for large facilities and specialized industrial environments.",
    href: "/commercial-overhead-contact-cleaning",
    icon: "industrial" as const,
  },
];

const serviceAreas = [
  "Central Florida",
  "Orlando Market",
  "Tampa Market",
  "Lakeland Market",
  "Ocala Market",
  "Daytona Market",
  "Melbourne Market",
  "Spring Hill Market",
  "Homosassa Springs Market",
  "Port St. Lucie Market",
  "Sebring Market",
  "Sarasota Market",
  "Gainesville Market",
  "The Villages Market",
  "Palm Coast Market",
  "DeLand / Deltona Market",
];

const trustPoints = [
  "Serving Florida homes and businesses since 2002.",
  "Certified teams for air duct, dryer vent, and chimney cleaning.",
  "High-powered truck-mounted vacuum equipment for source-removal cleaning.",
  "Before-and-after project documentation available.",
];

const specialtyServices = [
  "Air duct cleaning for residential, commercial, and industrial systems",
  "Dryer duct cleaning and repairs focused on fire prevention",
  "Chimney cleaning and repair support for safer venting",
  "High-dust zone and combustible dust contact cleaning",
];
---

<SiteLayout
  title="Air Duct, Dryer Vent & Chimney Cleaning in Central Florida"
  description="Hygienic Air, Inc provides residential, commercial, and industrial air duct, dryer vent, chimney, and high-dust cleaning services across Central Florida."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    imageUrl={heroImageUrl}
    title="Experience the Difference with Clean Air Solutions"
    body="Hygienic Air, Inc: Central Florida's premier duct cleaning experts, ensuring healthier indoor air quality since 2002."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      crossorigin=""
    />
    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      crossorigin=""
      defer
    ></script>
  </Fragment>

  <section class="section section--services">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Our Services</p>
        <h2 class="section-title">Powerful Solutions</h2>
        <p>
          At Hygienic Air, Inc, your satisfaction and well-being are our top priorities.
          Experience the difference with our comprehensive services and let us help you breathe easier.
        </p>
      </header>

      <div class="service-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-icon-wrap" aria-hidden="true">
              <ServiceIcon variant={service.icon} />
            </div>
            <h3>{service.title}</h3>
            <p>{service.body}</p>
            <a href={service.href}>Explore {service.title}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--gallery" id="explore-our-work">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Explore Our Work</p>
        <h2 class="section-title">Recent Projects & Jobsite Highlights</h2>
        <p>Take a glimpse into our world of precision and professionalism with our gallery showcasing our finest projects. See the difference quality makes!</p>
      </header>
      <div class="gallery-masonry" id="home-gallery">
        {homeGalleryImages.map((item, idx) => (
          <a href={item.src.src} data-lightbox-item data-index={idx} aria-label={`Open gallery image ${idx + 1}`}>
            <Image
              src={item.src}
              alt={item.alt}
              loading="lazy"
              width={900}
              sizes="(min-width: 68rem) 33vw, (min-width: 42rem) 50vw, 100vw"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Why Homeowners & Businesses Choose Us</p>
        <h2 class="section-title">Trusted Results, Specialized Services, and Clear Communication</h2>
      </header>

      <div class="split-grid">
        <article class="notice-box">
          <h3>What You Can Expect</h3>
          <ul class="feature-list">
            {trustPoints.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="notice-box">
          <h3>Services Available</h3>
          <ul class="feature-list">
            {specialtyServices.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--reviews">
    <div class="u-container reviews-grid">
      <div class="reviews-copy content-stack">
        <p class="section-topper content-stack__topper">Customer Reviews</p>
        <h2 class="section-title content-stack__title">Trusted by Florida Homeowners & Businesses</h2>
        <p class="content-stack__body">
          Discover why our customers trust us for all their ventilation cleaning needs. Your satisfaction is our priority!
        </p>
        <a href="/reviews" class="btn btn--secondary-light content-stack__actions">Read More Reviews</a>
      </div>

      <TestimonialSlider id="home-review-slider" label="Homepage testimonial slider" items={testimonials} />
    </div>
  </section>

  <section class="section section--areas">
    <div class="u-container areas-grid">
      <div class="content-stack">
        <p class="section-topper content-stack__topper">Areas We Serve</p>
        <h2 class="section-title content-stack__title">Bringing Powerful Air Quality Solutions to Your Area</h2>
        <p class="content-stack__body">
          Our crews are equipped with state-of-the-art vacuum trucks, ready to take on
          residential and commercial duct cleaning projects across Florida.
        </p>
        <ul class="areas-list">
          {serviceAreas.map((area) => <li>{area}</li>)}
        </ul>
      </div>

      <div class="map-wrap">
        <div
          id="home-service-area-map"
          class="service-area-map"
          role="img"
          aria-label="OpenStreetMap showing Hygienic Air service area locations across Central Florida"
        ></div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const marketPins = [
        { name: "Central Florida", lat: 28.5494, lng: -81.7729 },
        { name: "Orlando Market", lat: 28.5383, lng: -81.3792 },
        { name: "Tampa Market", lat: 27.9506, lng: -82.4572 },
        { name: "Lakeland Market", lat: 28.0395, lng: -81.9498 },
        { name: "Ocala Market", lat: 29.1872, lng: -82.1401 },
        { name: "Daytona Market", lat: 29.2108, lng: -81.0228 },
        { name: "Melbourne Market", lat: 28.0836, lng: -80.6081 },
        { name: "Spring Hill Market", lat: 28.4761, lng: -82.5255 },
        { name: "Homosassa Springs Market", lat: 28.8036, lng: -82.5759 },
        { name: "Port St. Lucie Market", lat: 27.273, lng: -80.3582 },
        { name: "Sebring Market", lat: 27.4956, lng: -81.4409 },
        { name: "Sarasota Market", lat: 27.3364, lng: -82.5307 },
        { name: "Gainesville Market", lat: 29.6516, lng: -82.3248 },
        { name: "The Villages Market", lat: 28.927, lng: -82.0038 },
        { name: "Palm Coast Market", lat: 29.5845, lng: -81.2079 },
        { name: "DeLand / Deltona Market", lat: 28.9645, lng: -81.2834 },
      ];

      const initServiceAreaMap = () => {
        const mapElement = document.getElementById("home-service-area-map");
        if (!mapElement || mapElement.dataset.bound === "true" || typeof window.L === "undefined") return;
        mapElement.dataset.bound = "true";

        const map = window.L.map(mapElement, {
          scrollWheelZoom: false,
          zoomControl: true,
        });

        window.L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        }).addTo(map);

        const bounds = window.L.latLngBounds([]);

        marketPins.forEach((market) => {
          window.L.marker([market.lat, market.lng]).addTo(map).bindPopup(`<strong>${market.name}</strong>`);
          bounds.extend([market.lat, market.lng]);
        });

        map.fitBounds(bounds.pad(0.12));
        window.setTimeout(() => map.invalidateSize(), 120);
      };

      const bootMap = () => {
        if (typeof window.L !== "undefined") {
          initServiceAreaMap();
          return;
        }

        let attempts = 0;
        const pollId = window.setInterval(() => {
          attempts += 1;
          if (typeof window.L !== "undefined") {
            window.clearInterval(pollId);
            initServiceAreaMap();
            return;
          }

          if (attempts > 50) {
            window.clearInterval(pollId);
          }
        }, 100);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bootMap, { once: true });
      } else {
        bootMap();
      }

      document.addEventListener("astro:page-load", bootMap);
    })();
  </script>

  <section class="section section--home-assistance">
    <div class="u-container home-assistance">
      <header class="section__head content-stack">
        <p class="section-topper">Need Help?</p>
        <h2 class="section-title">Have questions or need assistance?</h2>
            <p class="home-assistance__copy">
        We're here to help! Fill out the form below and a member of our team will get back to you
        as soon as possible.
      </p>
      </header>

      <div class="home-assistance__lead-form">
        <iframe
          title="Housecall Pro Lead Form Page"
          src="https://book.housecallpro.com/lead-form/Hygienic-Air-Inc/7e7d0cd761eb492ea0c1ddd36b69f5c7?buttonColor=rgba%28255%2C+255%2C+255%2C+1%29&buttonTextColor=rgba%2835%2C+62%2C+132%2C+1%29"
          class="hcp-lead-form-page"
          id="hcp-lead-iframe"
          style="border: medium; width: 100%; height: 100%;"
        ></iframe>
      </div>

      <div class="home-assistance__financing">
        <div class="home-assistance__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 96 96">
            <path d="m83.58 65.6-4.13 20.25a2 2 0 0 1-1.77 1.59c-2.24.21-5.42.49-7.29.49-34.91 0-63.31-29.79-63.31-66.4a69.28 69.28 0 0 1 .4-7.39 2 2 0 0 1 2-1.79h21.76a2 2 0 0 1 2 1.63l4 21.39a2 2 0 0 1-.46 1.69l-6.52 7.41a61 61 0 0 0 20 19.28l11.94-7.68a2 2 0 0 1 1.8-.17l18.36 7.45a2 2 0 0 1 1.22 2.25Zm-5.45-46.74A37.19 37.19 0 0 0 54.29 8.07a2 2 0 0 0-2.13 1.87A2 2 0 0 0 54 12.06 33.11 33.11 0 0 1 84.93 43a2 2 0 0 0 2 1.87h.14a2 2 0 0 0 1.86-2.12 37.19 37.19 0 0 0-10.8-23.89ZM53.2 23.58a21.56 21.56 0 0 1 20.22 20.21 2 2 0 0 0 2 1.87h.13a2 2 0 0 0 1.87-2.12 25.56 25.56 0 0 0-23.95-24 2 2 0 1 0-.26 4Zm-.81 11.49a10.09 10.09 0 0 1 9.53 9.53 2 2 0 0 0 2 1.89H64a2 2 0 0 0 1.88-2.11 14.07 14.07 0 0 0-13.26-13.3 2 2 0 0 0-.23 4Z"></path>
          </svg>
        </div>
        <div class="home-assistance__financing-content">
          <p>
            We Have Financing Options Available. Give us a call to find out more info!
          </p>
          <a
            class="btn btn--secondary-light"
            href="http://wisetack.us/#/mxr0gum/prequalify"
            target="_blank"
            rel="noreferrer"
          >
            Discover Financial Solutions
          </a>
        </div>
      </div>
    </div>
  </section>

  <Lightbox slot="after-body" />
</SiteLayout>
