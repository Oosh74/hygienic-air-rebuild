---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import { Image } from "astro:assets";

import aboutIntroImage from "@assets/images/services/about-intro.jpg";
import serviceResidentialAirDuctImage from "@assets/images/services/residential-air-duct-hero.jpg";
import serviceResidentialDryerImage from "@assets/images/services/residential-dryer-duct-hero.jpg";
import serviceResidentialChimneyImage from "@assets/images/services/residential-chimney-hero.jpg";
import serviceCommercialAirDuctImage from "@assets/images/services/commercial-air-duct-hero.jpg";
import serviceCommercialDryerImage from "@assets/images/services/commercial-dryer-duct-hero.jpg";
import serviceCommercialChimneyImage from "@assets/images/services/commercial-chimney-hero.jpg";
import serviceHighDustImage from "@assets/images/services/high-dust-zone-hero.jpg";

const heroImageUrl =
  "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/Untitled+design+-+2024-04-24T021534.002-1920w.jpg";

const aboutLinks = [
  {
    title: "Certifications",
    href: "/certifications",
    body: "Review the credentials, memberships, and standards that guide our field practices.",
    icon: "certificate",
  },
  {
    title: "Industry Scams",
    href: "/industry-scams",
    body: "Learn how to identify low-quality offers and choose reputable service providers.",
    icon: "shield",
  },
  {
    title: "FAQs",
    href: "/faqs",
    body: "Get answers to common questions about cleaning frequency, process, and pricing.",
    icon: "faq",
  },
  {
    title: "Our Equipment",
    href: "/our-equipment",
    body: "See the high-powered equipment we use for complete source-removal cleaning.",
    icon: "equipment",
  },
];

const serviceHighlights = [
  {
    title: "Residential Air Duct Cleaning",
    href: "/residential-air-duct-cleaning",
    body: "Improve airflow and indoor air quality with source-removal duct cleaning designed for homes.",
    image: serviceResidentialAirDuctImage,
  },
  {
    title: "Residential Dryer Duct Cleaning / Repairs",
    href: "/residential-dryer-duct-cleaning-repairs",
    body: "Reduce dryer fire risk and restore performance with certified vent inspections, cleaning, and repairs.",
    image: serviceResidentialDryerImage,
  },
  {
    title: "Residential Chimney Cleaning / Repairs",
    href: "/residential-chimney-cleaning-repairs",
    body: "Keep chimney systems safer and code-conscious with annual sweeps and repair guidance.",
    image: serviceResidentialChimneyImage,
  },
  {
    title: "Commercial Air Duct Cleaning",
    href: "/commercial-air-duct-cleaning",
    body: "Support cleaner facility airflow and better HVAC performance with commercial source-removal service.",
    image: serviceCommercialAirDuctImage,
  },
  {
    title: "Commercial Dryer Duct Cleaning / Repairs",
    href: "/commercial-dryer-duct-cleaning-repairs",
    body: "Maintain code-aware dryer vent performance in high-use environments with safer system operation.",
    image: serviceCommercialDryerImage,
  },
  {
    title: "Commercial Chimney Cleaning / Repairs",
    href: "/commercial-chimney-cleaning-repairs",
    body: "Protect fuel-venting systems and reduce operational risk with thorough chimney service.",
    image: serviceCommercialChimneyImage,
  },
  {
    title: "High-Dust Zone Contact Cleaning",
    href: "/commercial-overhead-contact-cleaning",
    body: "Target overhead beams, structures, and hard-to-reach areas where combustible dust accumulates.",
    image: serviceHighDustImage,
  },
];
---

<SiteLayout
  title="About Us | Hygienic Air, Inc"
  description="Learn about Hygienic Air, our standards, certifications, equipment, and customer-focused approach to air system cleaning services."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="About Hygienic Air"
    title="Trusted Air System Cleaning Since 2002"
    body="We serve Florida homeowners and businesses with reliable crews, professional equipment, and a process built around safety, transparency, and results."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      { href: "/services", label: "Explore Services", variant: "secondary" },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Who We Are</p>
        <h2 class="section-title">Experience, Standards, and Accountability</h2>
      </header>

      <div class="split-grid about-intro-grid">
        <div class="rich-text">
          <p>
            Hygienic Air, Inc has spent more than two decades helping clients improve indoor air
            quality through detailed duct, dryer vent, and chimney services. Our approach combines
            trained technicians, high-capacity equipment, and clear communication from quote to
            completion.
          </p>
        </div>

        <figure class="about-intro-media">
          <Image
            src={aboutIntroImage}
            alt="Hygienic Air service truck and technicians preparing equipment on site."
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--about-services">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Our Services</p>
        <h2 class="section-title">Complete Residential and Commercial Solutions</h2>
      </header>

      <div class="service-highlight-list">
        {serviceHighlights.map((service, index) => (
          <article class:list={["service-highlight", { "service-highlight--reverse": index % 2 === 1 }]}>
            <div class="service-highlight__content content-stack">
              <h3 class="section-title">{service.title}</h3>
              <p>{service.body}</p>
              <a href={service.href}>View Service</a>
            </div>

            <figure class="service-highlight__media">
              <Image src={service.image} alt={service.title} loading="lazy" />
            </figure>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">About Us Resources</p>
        <h2 class="section-title">Explore More</h2>
      </header>

      <div class="info-card-grid about-resources-grid">
        {aboutLinks.map((item) => (
          <article class="info-card about-resource-card">
            <div class="about-resource-card__icon" aria-hidden="true">
              {item.icon === "certificate" && (
                <svg viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
                  <path d="M48 9a27 27 0 1 0 0 54 27 27 0 0 0 0-54Zm0 8a19 19 0 1 1 0 38 19 19 0 0 1 0-38Zm-22.5 50.6L18 88l14.6-5.8 8.2 4 7.2-12.2a35.1 35.1 0 0 1-22.5-6.4Zm45 0a35.1 35.1 0 0 1-22.5 6.4L55.2 86l8.2-4L78 88l-7.5-20.4Z"></path>
                </svg>
              )}
              {item.icon === "shield" && (
                <svg viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
                  <path d="M48 8 15 20v24c0 20.8 14 39.2 33 44 19-4.8 33-23.2 33-44V20L48 8Zm0 9.2 25 9.1V44c0 16.1-10.3 30.4-25 34.8C33.3 74.4 23 60.1 23 44V26.3l25-9.1Zm-5.7 19.1-5.6 5.7L44 49l15.7-15.8-5.7-5.6L44 37.7l-1.7-1.4Z"></path>
                </svg>
              )}
              {item.icon === "faq" && (
                <svg viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
                  <path d="M48 10C26.5 10 9 25.7 9 45c0 10.3 5.1 19.6 13.3 26L20 88l16.2-8.7c3.8 1.1 7.7 1.7 11.8 1.7 21.5 0 39-15.7 39-35S69.5 10 48 10Zm0 63c-3.7 0-7.3-.6-10.7-1.8l-1.8-.6-6.9 3.7 1-7.2-1.7-1.3C22 61.6 17 53.6 17 45c0-14.9 13.9-27 31-27s31 12.1 31 27-13.9 28-31 28Zm0-44c-8.6 0-15 4.7-15 11h8c0-1.8 2.8-3 7-3s7 1.2 7 3c0 1.2-.8 2.2-3.7 3.7-3.4 1.8-8.3 4.2-8.3 10.3v2h8v-2c0-1.2.8-2.2 3.7-3.7 3.4-1.8 8.3-4.2 8.3-10.3 0-6.3-6.4-11-15-11Zm-4 33h8v8h-8z"></path>
                </svg>
              )}
              {item.icon === "equipment" && (
                <svg viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 18h72v10H12zM18 34h60v44H18zm8 8v28h44V42zm10 8h24v12H36zM8 82h80v8H8z"></path>
                </svg>
              )}
            </div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <a href={item.href}>Go to {item.title}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ContactOptionsSection />
</SiteLayout>
