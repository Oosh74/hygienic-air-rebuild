---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import ImageCarousel from "@components/Site/ImageCarousel.astro";
import Lightbox from "@components/Site/Lightbox.astro";

const heroImageUrl = "/images/heroes/residential-dryer-duct-hero.jpg";

const warningSigns = [
  "Are you running your dryer multiple times to dry one load?",
  "Do your clothes smell hot or burnt after a cycle?",
  "Has your vent not been professionally cleaned in the last year?",
  "Does the laundry room feel unusually hot or humid?",
  "Is the dryer exterior hot to the touch?",
  "Are lint levels increasing around the appliance?",
  "Is the dryer flow sensor or blockage light on?",
];

const processSteps = [
  "Connect a power vacuum truck to place the line under negative pressure.",
  "Use proper agitation tools to remove compacted lint and debris.",
  "Inspect termination points and confirm safe airflow.",
  "Recommend compliant vent cover upgrades where needed.",
  "Document findings and leave the area clean.",
];

const galleryItems = [
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/aHR0cHM6Ly9jb21wYW55Y2FtLXBlbmRpbmcuczMuYW1hem9uYXdzLmNvbS83N2RmNDE2Mi00YjNiLTQxMzYtYmFmNy0yZjZiNjc4ZGQ5MDIuanBn-b997edd0-1920w.jpeg",
    alt: "Dryer vent service setup at a residential property.",
  },
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/20210106_090947-16042c8e-5931f315-1920w.jpg",
    alt: "Technician inspecting a residential dryer vent exit.",
  },
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/336761177_750350489820967_6735450353802090564_n-8431bf98-1920w.jpg",
    alt: "Dryer duct cleaning tools and equipment in use.",
  },
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/337032203_1291816934704016_6389814168425175620_n-619d12cf-1920w.jpg",
    alt: "Team performing professional dryer vent cleaning.",
  },
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/goose-neck-lint-blockage-838f5778-da2a2bf3-1920w.jpg",
    alt: "Example of severe lint blockage in a dryer vent.",
  },
  {
    src: "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/Screenshot-2024-06-17-203508-1-1920w.png",
    alt: "Residential dryer vent cover option.",
  },
];
---

<SiteLayout
  title="Residential Dryer Duct Cleaning | Hygienic Air, Inc"
  description="Certified residential dryer duct cleaning and repair services focused on fire prevention, safer operation, and efficient drying performance."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Residential Service"
    title="Residential Dryer Duct Cleaning / Repair"
    body="We prioritize fire safety with certified dryer duct inspections, code-aware repairs, and high-powered cleaning methods designed for lasting performance."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Why Dryer Vent Cleaning Is Important</p>
        <h2 class="section-title">Protect Your Home from Dryer Fire Risks</h2>
      </header>

      <div class="split-grid content-grid">
        <div class="rich-text">
          <p>
            Dryer vent cleaning removes lint and debris from the full exhaust path, from behind
            the dryer to the outside termination. According to NFPA guidance, failure to clean
            dryer vents is a leading cause of dryer-related fires.
          </p>
          <p>
            Clogged lines force the dryer to run longer, increase wear, and can lead to overheating,
            elevated utility costs, and carbon monoxide risks in fuel-burning systems.
          </p>
          <p>
            We also help homeowners address common code and safety issues, including improper
            termination screens that trap lint and restrict airflow.
          </p>
        </div>

        <aside class="notice-box">
          <h3>Warning Signs It's Time to Clean</h3>
          <ul class="check-list">
            {warningSigns.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">Our Process</p>
        <h2 class="section-title">Why Our Dryer Duct Cleaning Stands Out</h2>
      </header>

      <div class="info-card-grid">
        <article class="info-card">
          <h3>Certified Technicians</h3>
          <p>
            Our team includes CSIA-certified dryer duct technicians with focused training in fire
            prevention and safe vent restoration.
          </p>
        </article>

        <article class="info-card">
          <h3>High-Powered Equipment</h3>
          <p>
            We use professional vacuum and agitation systems to remove packed lint that basic tools
            or leaf-blower methods can leave behind.
          </p>
        </article>

        <article class="info-card">
          <h3>Safety & Compliance Focus</h3>
          <p>
            We inspect vent terminations and provide practical recommendations for compliant covers
            and safer long-term operation.
          </p>
        </article>
      </div>

      <div class="notice-box" style="margin-top: var(--space-l);">
        <h3>Typical Service Workflow</h3>
        <ul class="feature-list">
          {processSteps.map((step) => <li>{step}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">View Our Gallery</p>
        <h2 class="section-title">Residential Dryer Vent Projects</h2>
      </header>

      <ImageCarousel
        id="residential-dryer-gallery"
        label="Residential dryer vent project gallery"
        items={galleryItems}
        fit="contain"
      />
    </div>
  </section>

  <ContactOptionsSection />

  <Lightbox slot="after-body" />
</SiteLayout>
