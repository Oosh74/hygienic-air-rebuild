---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";

const heroImageUrl =
  "https://lirp.cdn-website.com/e5bcce9c/dms3rep/multi/opt/Untitled+design+-+2024-04-24T021534.002-1920w.jpg";

const mapEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3505.452285900647!2d-81.72405632450307!3d28.526122175723025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88e7bd3a9d843b11%3A0xc2a2c16e7adc5be2!2sHygienic%20Air%20Plus!5e0!3m2!1sen!2sus!4v1773173616641!5m2!1sen!2sus";
---

<SiteLayout
  title="Contact | Hygienic Air, Inc"
  description="Contact Hygienic Air for residential and commercial duct, dryer vent, chimney, and overhead cleaning services in Florida."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Contact Hygienic Air"
    title="Get in Touch"
    body="Have questions, need a quote, or want to schedule service? Call, email, or send us a request and our team will follow up promptly."
    actions={[
      { href: "tel:+13528012788", label: "Call (352) 801-2788", variant: "primary" },
      { href: "mailto:info@hygienicairplus.com", label: "Email Us", variant: "secondary" },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container contact-form-grid">
      <div class="contact-lead-form">
        <iframe
          title="Housecall Pro Lead Form Page"
          src="https://book.housecallpro.com/lead-form/Hygienic-Air-Inc/7e7d0cd761eb492ea0c1ddd36b69f5c7?buttonColor=rgba%28255%2C+255%2C+255%2C+1%29&buttonTextColor=rgba%2835%2C+62%2C+132%2C+1%29"
          class="hcp-lead-form-page"
          id="contact-hcp-lead-iframe"
          style="border: medium; width: 100%; height: 100%;"
        ></iframe>
      </div>

      <aside class="notice-box">
        <h3>Contact Details</h3>
        <p><strong>Phone:</strong> <a href="tel:+13528012788">(352) 801-2788</a></p>
        <p><strong>Email:</strong> <a href="mailto:info@hygienicairplus.com">info@hygienicairplus.com</a></p>
        <p>
          <strong>Address:</strong><br />
          1880 Nature Cove Ln<br />
          Clermont, FL 34711
        </p>

        <div class="map-wrap" style="margin-top: var(--space-s);">
          <iframe
            src={mapEmbedSrc}
            width="600"
            height="450"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Hygienic Air location map"
          ></iframe>
        </div>
      </aside>
    </div>
  </section>
</SiteLayout>
