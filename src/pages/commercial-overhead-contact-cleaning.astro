---
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ServiceIcon from "@components/Site/ServiceIcon.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";

const heroImageUrl = "/images/heroes/high-dust-zone-hero.jpg";

const whatWeClean = [
  {
    title: "Wall Niche Detail",
    body: "Architectural cutouts and decorative recesses that quietly collect dust, cobwebs, and pet hair.",
    icon: "residential" as const,
  },
  {
    title: "Ceiling Fan Precision",
    body: "Blades, motor housings, and mounting hardware that can redistribute allergens and dust throughout occupied spaces.",
    icon: "commercial" as const,
  },
  {
    title: "Cabinet Top Sweep",
    body: "Upper surfaces in kitchens, laundry rooms, and break areas where grease-laced dust builds up over time.",
    icon: "industrial" as const,
  },
  {
    title: "Exposed Ductwork & Beams",
    body: "Structural and decorative elements that are difficult to reach during routine cleaning in loft-style and commercial spaces.",
    icon: "commercial" as const,
  },
  {
    title: "Ledges & Transoms",
    body: "High window ledges and decorative trim details where dust and pollen accumulate over long periods.",
    icon: "residential" as const,
  },
  {
    title: "Additional Specialty Surfaces",
    body: "Service scope is customized for specialty overhead zones based on layout, occupancy, and usage.",
    icon: "industrial" as const,
  },
];

const howWeClean = [
  "Manual contact cleaning using HEPA-filtered vacuums, microfiber cloths, and extension tools.",
  "Safe access protocols with ladders, step stools, containment barriers, and OSHA-aware practices.",
  "Protective prep including drop cloths and area protection for floors, furniture, and fixtures.",
  "Before-and-after photo documentation for cleaned surfaces.",
  "No blow-and-go shortcuts: surfaces are physically contacted, cleaned, and verified.",
];

const whoBenefits = [
  "Residential homes with high ceilings, niches, and decorative architectural features",
  "Commercial offices, retail, and hospitality spaces where cleanliness and presentation matter",
  "Property turnover projects, seasonal resets, and inspection prep",
  "Real estate professionals preparing staged homes for listing and showings",
  "Clients pairing overhead cleaning with full air duct cleaning for better indoor results",
];
---

<SiteLayout
  title="High-Dust Zone & Combustible Dust Cleaning in Central Florida"
  description="High-dust zone and combustible dust contact cleaning services in Central Florida for elevated surfaces that affect indoor air quality, safety, and facility cleanliness."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Commercial / Industrial Service"
    title="High-Dust Zone Contact Cleaning / Combustible Dust"
    body="Cleaner air starts with cleaner surfaces. We target elevated dust zones that standard routines often miss."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      {
        href: "https://client.housecallpro.com/customer_portal/request-link?token=e189962ac4d546e3b9e813944ff69b3c",
        label: "Book Online",
        variant: "secondary",
        external: true,
      },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">Why It Matters</p>
        <h2 class="section-title">The Perfect Companion to Air Duct Cleaning</h2>
      </header>

      <div class="split-grid content-grid">
        <div class="rich-text">
          <p>
            High-Dust Zone Contact Cleaning was developed to address elevated buildup that impacts
            air quality, comfort, and overall cleanliness. These surfaces often go unnoticed yet
            can continuously reintroduce fine debris into occupied environments.
          </p>
          <p>
            This service can stand alone or pair with duct cleaning for a fuller indoor air
            quality strategy: one clears the system, the other clears the space.
          </p>
        </div>

        <aside class="notice-box">
          <h3>Cleaning Frequency</h3>
          <p>
            Service intervals are tailored to each home or facility based on dust load, occupancy,
            ceiling height, and environmental conditions.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="u-container">
      <header class="section__head content-stack">
        <p class="section-topper">What We Clean</p>
        <h2 class="section-title">Precision Cleaning for Hard-to-Reach Surfaces</h2>
      </header>

      <div class="tile-grid">
        {whatWeClean.map((item) => (
          <article class="tile-card">
            <div class="card-icon-wrap" aria-hidden="true">
              <ServiceIcon variant={item.icon} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="u-container split-grid">
      <article class="notice-box">
        <h3>How We Clean</h3>
        <ul class="feature-list">
          {howWeClean.map((step) => <li>{step}</li>)}
        </ul>
      </article>

      <article class="notice-box">
        <h3>Who Benefits</h3>
        <ul class="feature-list">
          {whoBenefits.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <ContactOptionsSection />
</SiteLayout>
