---
import { Image } from "astro:assets";
import SiteLayout from "@layouts/SiteLayout.astro";
import HeroSection from "@components/Site/HeroSection.astro";
import ContactOptionsSection from "@components/Site/ContactOptionsSection.astro";
import Lightbox from "@components/Site/Lightbox.astro";
import { galleryPageImages } from "@data/gallery-images";

const heroImageUrl = "/images/heroes/gallery-hero.jpg";
---

<SiteLayout
  title="Air Duct Cleaning Project Gallery | Hygienic Air Plus"
  description="Browse real residential, commercial, and industrial duct cleaning project photos from Hygienic Air teams serving Central Florida."
  imageUrl={heroImageUrl}
  overlayHeader={true}
>
  <HeroSection
    align="left-bottom"
    imageUrl={heroImageUrl}
    topper="Explore Our Work"
    title="Our Gallery"
    body="No job is too small or too large for the Hygienic Air team. Explore real project photos from homes, commercial facilities, and industrial environments."
    actions={[
      { href: "tel:+13528012788", label: "Call Us", variant: "primary" },
      { href: "/services", label: "View Services", variant: "secondary" },
    ]}
  />

  <section class="section section--page-intro">
    <div class="u-container">
      <header class="section__head section__head--left content-stack">
        <p class="section-topper">The Hygienic Way</p>
        <h2 class="section-title">Browse Our Projects</h2>
      </header>

      <div class="rich-text">
        <p>
         With over 20 years of experience, we specialize in cleaning homes, commercial institutions, and industrial buildings. Our team provides thorough and efficient cleaning services, ensuring your air ducts and dryer vents are spotless and functioning optimally.


We use state-of-the-art equipment and follow industry best practices to deliver top- notch results. Our experienced technicians are trained to handle any cleaning challenge, big or small, with precision and care. Trust us to improve the air quality in your space and enhance the efficiency of your HVAC systems.
        </p>
        <p>
          These photos highlight real service conditions, equipment deployment, and completion
          results from projects completed across our Florida coverage area.
        </p>
      </div>

      <div class="gallery-masonry" style="margin-top: var(--space-l);">
        {galleryPageImages.map((item, idx) => (
          <a href={item.src.src} data-lightbox-item data-index={idx} aria-label={`Open gallery image ${idx + 1}`}>
            <Image
              src={item.src}
              alt={item.alt}
              loading="lazy"
              width={1200}
              sizes="(min-width: 68rem) 33vw, (min-width: 42rem) 50vw, 100vw"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactOptionsSection />

  <Lightbox slot="after-body" />
</SiteLayout>
